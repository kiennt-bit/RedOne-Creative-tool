<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   Version="8.0"
                   ExtensionBundleId="com.redone.genfill"
                   ExtensionBundleVersion="1.0.0"
                   ExtensionBundleName="RedOne GenFill">

  <ExtensionList>
    <Extension Id="com.redone.genfill.panel" Version="1.0.0" />
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- Photoshop CC 2015.5+ (v17) through CC 2025+ (v26) -->
      <Host Name="PHXS" Version="[17.0,99.9]" />
      <Host Name="PHSP" Version="[17.0,99.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="8.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.redone.genfill.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/photoshop.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>RedOne GenFill</Menu>
          <Geometry>
            <Size>
              <Height>600</Height>
              <Width>320</Width>
            </Size>
            <MinSize>
              <Height>400</Height>
              <Width>280</Width>
            </MinSize>
            <MaxSize>
              <Height>1200</Height>
              <Width>600</Width>
            </MaxSize>
          </Geometry>

        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
