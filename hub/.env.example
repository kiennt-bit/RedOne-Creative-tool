# ───────────────────────────────────────────────────────────────────
# RedOne Hub — config. Copy this file to `.env` and fill in values.
# (Nothing here is committed with real secrets — keep `.env` private.)
# ───────────────────────────────────────────────────────────────────

# ── Docker Compose (bundled Postgres) — set a STRONG password. Compose builds
# DATABASE_URL from this automatically and ignores the DATABASE_URL below. ──
POSTGRES_PASSWORD=change-this-strong-password

# ── Database (DB-agnostic via SQLAlchemy). Used only when running uvicorn
# DIRECTLY (not via docker-compose). Pick ONE: ──
DATABASE_URL=sqlite:///./hub.db
# DATABASE_URL=postgresql+psycopg2://hub:PASSWORD@localhost:5432/redone_hub
# DATABASE_URL=mysql+pymysql://hub:PASSWORD@localhost:3306/redone_hub

# ── Identity — MUST match the desktop tool ──
# OAUTH_CLIENT_ID = the SAME value as the tool's backend/private_config.py
# (OAUTH_CLIENT_ID). The Hub verifies Google id_tokens against this.
OAUTH_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
ALLOWED_DOMAIN=redone.vn

# First admin(s) — comma-separated emails. Seeded as role=admin on first
# login. Can be changed/relinquished later from the in-app "Quản trị" tab.
BOOTSTRAP_ADMIN_EMAIL=kiennt@redone.vn

# Secret used to sign Hub session tokens. Set a long random string in prod:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
HUB_JWT_SECRET=
HUB_TOKEN_DAYS=30

# Public base URL of THIS Hub (used to build media links for local storage).
PUBLIC_BASE_URL=https://hub.redone.vn

# ── Media storage ──
# local = this server's disk (MEDIA_DIR).  s3 = object storage (below).
STORAGE_BACKEND=local
MEDIA_DIR=./media
SIGNED_URL_TTL=86400

# If STORAGE_BACKEND=s3 (AWS S3 / Cloudflare R2 / Backblaze B2):
# S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=redone-hub-media
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_PUBLIC_BASE_URL=                # optional R2/S3 public custom domain

# ── Quota defaults (per user until admin overrides). -1 = unlimited ──
DEFAULT_QUOTA_LIMIT=-1
DEFAULT_QUOTA_PERIOD=monthly

# CORS — the tool calls server-to-server, so usually leave as *.
CORS_ORIGINS=*
